<Window x:Class="CyberSecurityBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot"
        Height="750"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid>

        <TabControl Background="#0F172A"
                    BorderBrush="#1E293B"
                    Foreground="White">

            <!-- ================= CHATBOT TAB ================= -->
            <TabItem Header="💬 Chatbot">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- CHAT DISPLAY -->
                    <TextBox x:Name="ChatBox"
                             Grid.Row="0"
                             Margin="5"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="#111827"
                             Foreground="White"
                             FontSize="14"
                             Padding="10"/>

                    <!-- INPUT AREA -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="5">

                        <TextBox x:Name="InputBox"
                                 Width="650"
                                 Height="40"
                                 FontSize="14"
                                 Padding="5"
                                 KeyDown="InputBox_KeyDown"
                                 Background="#1F2937"
                                 Foreground="White"
                                 BorderBrush="#334155"/>

                        <Button Content="Send"
                                Width="100"
                                Height="40"
                                Margin="10,0,0,0"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="Bold"
                                Click="SendButton_Click"/>
                    </StackPanel>

                </Grid>

            </TabItem>

            <!-- ================= TASKS TAB ================= -->
            <TabItem Header="🗂 Tasks">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="TaskTitleBox"
                             Height="35"
                             Margin="0,5"
                             FontSize="14"
                             Background="#1F2937"
                             Foreground="White"/>

                    <TextBox x:Name="TaskDescBox"
                             Grid.Row="1"
                             Height="35"
                             Margin="0,5"
                             FontSize="14"
                             Background="#1F2937"
                             Foreground="White"/>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,5">

                        <Button Content="Add Task"
                                Width="120"
                                Click="AddTask_Click"
                                Background="#22C55E"
                                Foreground="White"/>

                        <Button Content="Load Tasks"
                                Width="120"
                                Margin="10,0,0,0"
                                Click="LoadTasks_Click"
                                Background="#3B82F6"
                                Foreground="White"/>

                        <Button Content="Delete Task"
                                Width="120"
                                Margin="10,0,0,0"
                                Click="DeleteTask_Click"
                                Background="#EF4444"
                                Foreground="White"/>
                    </StackPanel>

                    <ListBox x:Name="TaskListBox"
                             Grid.Row="3"
                             Margin="0,10,0,0"
                             Background="#111827"
                             Foreground="White"/>

                </Grid>

            </TabItem>

            <!-- ================= QUIZ TAB ================= -->
            <TabItem Header="🎮 Quiz">

                <StackPanel Margin="15">

                    <TextBlock x:Name="QuizQuestion"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,10"/>

                    <Button x:Name="OptionA"
        Click="Option_Click"
        Background="#1F2937"
        Foreground="White"
        Height="40"
        Margin="0,5"/>

                    <Button x:Name="OptionB"
        Click="Option_Click"
        Background="#1F2937"
        Foreground="White"
        Height="40"
        Margin="0,5"/>

                    <Button x:Name="OptionC"
        Click="Option_Click"
        Background="#1F2937"
        Foreground="White"
        Height="40"
        Margin="0,5"/>

                    <Button x:Name="OptionD"
        Click="Option_Click"
        Background="#1F2937"
        Foreground="White"
        Height="40"
        Margin="0,5"/>

                    <TextBlock x:Name="QuizFeedback"
                               FontSize="16"
                               Foreground="#FACC15"
                               Margin="10"/>

                    <Button Content="Next Question"
                            Width="150"
                            Height="35"
                            Background="#8B5CF6"
                            Foreground="White"
                            Click="NextQuestion_Click"/>
                </StackPanel>

            </TabItem>

            <!-- ================= ACTIVITY LOG TAB ================= -->
            <TabItem Header="📊 Activity Log">

                <ListBox x:Name="LogListBox"
                         Margin="10"
                         Background="#111827"
                         Foreground="White"/>

            </TabItem>

        </TabControl>

    </Grid>
</Window>