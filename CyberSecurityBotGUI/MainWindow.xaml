<Window x:Class="CyberSecurityBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot"
        Height="700"
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#EAF4FC">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#1E3A5F"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,10">

            <StackPanel>

                <TextBlock Text="🛡 CYBERSECURITY AWARENESS BOT"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Stay Safe Online | Learn Cybersecurity Awareness"
                           FontSize="14"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>

            </StackPanel>

        </Border>

        <!-- CHAT DISPLAY -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="5">

            <TextBox x:Name="ChatBox"
                     FontSize="14"
                     FontFamily="Consolas"
                     Background="White"
                     BorderThickness="0"
                     Foreground="Black"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="True"/>
        </Border>

        <!-- INPUT AREA -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="10"
                Margin="0,10,0,0">

            <DockPanel>

                <Button x:Name="SendButton"
                        Content="Send"
                        Width="120"
                        Height="35"
                        FontWeight="Bold"
                        Background="#1E3A5F"
                        Foreground="White"
                        DockPanel.Dock="Right"
                        Margin="10,0,0,0"
                        Click="SendButton_Click"/>

                <TextBox x:Name="InputBox"
                         Height="35"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         KeyDown="InputBox_KeyDown"/>

            </DockPanel>

        </Border>

        <!-- FOOTER -->
        <TextBlock Grid.Row="3"
                   Text="Cybersecurity Awareness Assistant © 2026"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"
                   Foreground="Gray"
                   FontSize="12"/>

    </Grid>
</Window>